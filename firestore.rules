rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'company', 'status', 'ownerId', 'createdAt', 'updatedAt', 'value']) &&
             data.keys().size() <= 14 && 
             data.name is string && data.name.size() > 0 &&
             data.company is string && data.company.size() > 0 &&
             (!data.keys().contains('startDate') || data.startDate is string) &&
             (!data.keys().contains('endDate') || data.endDate is string) &&
             (!data.keys().contains('phone') || data.phone is string) &&
             data.status in ['new', 'qualified', 'proposal', 'closed'] &&
             data.ownerId == request.auth.uid &&
             data.value is number &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['leadId', 'title', 'completed', 'createdAt']) &&
             data.leadId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.completed is bool &&
             data.createdAt is timestamp;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['leadId', 'content', 'authorId', 'createdAt']) &&
             data.leadId is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.authorId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // --- Collections ---

    match /leads/{leadId} {
      allow get: if isSignedIn() && isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidLead(incoming()) && incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && 
                    isOwner(existing().ownerId) && 
                    isValidLead(incoming()) && 
                    incoming().updatedAt == request.time &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt;
      
      allow delete: if isSignedIn() && isOwner(existing().ownerId);

      // Subcollections
      match /tasks/{taskId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/leads/$(leadId)).data.ownerId == request.auth.uid;
        allow write: if isSignedIn() && 
                    get(/databases/$(database)/documents/leads/$(leadId)).data.ownerId == request.auth.uid &&
                    isValidTask(incoming());
      }

      match /notes/{noteId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/leads/$(leadId)).data.ownerId == request.auth.uid;
        allow write: if isSignedIn() && 
                    get(/databases/$(database)/documents/leads/$(leadId)).data.ownerId == request.auth.uid &&
                    isValidNote(incoming());
      }
    }
  }
}
